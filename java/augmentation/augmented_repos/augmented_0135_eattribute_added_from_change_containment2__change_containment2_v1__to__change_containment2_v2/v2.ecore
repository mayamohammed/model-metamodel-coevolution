    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="files" upperBound="-1" eType="//File"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="computedField_21">
      <eType xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EDouble"/>
    </eStructuralFeatures>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="File">
